# Build-time переменные для CI (npm run build).
# Локальная разработка использует .env.local — он перебивает этот файл.
# Значения заглушки для test-кубера — поправь под свои хосты перед первым релизом.

VITE_API_BASE_URL=https://pay-admin-api.test.tkbbank.ru
VITE_AUTH_ENABLED=true
VITE_KEYCLOAK_URL=https://keycloak.test.tkbbank.ru
VITE_KEYCLOAK_REALM=pay-admin
VITE_KEYCLOAK_CLIENT_ID=pay-admin-web
